<resources>
    <!-- Dark theme — auto-applied when system is in dark mode -->
    <style name="Theme.RestaurantApp" parent="Theme.Material3.DayNight.NoActionBar">
        <!-- Primary brand color stays the same in dark mode -->
        <item name="colorPrimary">@color/primary_light</item>
        <item name="colorPrimaryVariant">@color/primary</item>
        <item name="colorOnPrimary">@color/text_on_primary</item>

        <!-- Secondary -->
        <item name="colorSecondary">@color/secondary_light</item>
        <item name="colorOnSecondary">@color/black</item>

        <!-- Surface / Background — dark -->
        <item name="colorSurface">@color/surface</item>
        <item name="colorOnSurface">@color/text_primary</item>
        <item name="colorSurfaceVariant">@color/surface_variant</item>
        <item name="android:colorBackground">@color/background</item>
        <item name="colorOnBackground">@color/text_primary</item>

        <!-- Keep typography stable across light/dark modes -->
        <item name="android:fontFamily">sans-serif</item>
        <item name="fontFamily">sans-serif</item>

        <!-- Error -->
        <item name="colorError">@color/error</item>
        <item name="colorOnError">@color/black</item>

        <!-- Status bar -->
        <item name="android:statusBarColor">@color/surface</item>
        <item name="android:windowLightStatusBar">false</item>

        <!-- Navigation bar -->
        <item name="android:navigationBarColor">@color/surface</item>

        <!-- Button styles (inherit from day theme) -->
        <item name="materialButtonStyle">@style/Widget.App.Button</item>
        <item name="materialCardViewStyle">@style/Widget.App.CardView</item>
    </style>
</resources>