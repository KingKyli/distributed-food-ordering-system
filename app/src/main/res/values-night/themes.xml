<resources>
    <!-- Dark theme — auto-applied when system is in dark mode -->
    <style name="Theme.RestaurantApp" parent="Theme.Material3.DayNight.NoActionBar">
        <!-- Primary brand color stays the same in dark mode -->
        <item name="colorPrimary">#EF5350</item>
        <item name="colorPrimaryVariant">#D32F2F</item>
        <item name="colorOnPrimary">#FFFFFF</item>

        <!-- Secondary -->
        <item name="colorSecondary">#FF8A65</item>
        <item name="colorOnSecondary">#000000</item>

        <!-- Surface / Background — dark -->
        <item name="colorSurface">#1E1E1E</item>
        <item name="colorOnSurface">#EEEEEE</item>
        <item name="colorSurfaceVariant">#2C2C2C</item>
        <item name="android:colorBackground">#121212</item>
        <item name="colorOnBackground">#EEEEEE</item>

        <!-- Error -->
        <item name="colorError">#CF6679</item>
        <item name="colorOnError">#000000</item>

        <!-- Status bar -->
        <item name="android:statusBarColor">#1E1E1E</item>
        <item name="android:windowLightStatusBar">false</item>

        <!-- Navigation bar -->
        <item name="android:navigationBarColor">#1E1E1E</item>

        <!-- Button styles (inherit from day theme) -->
        <item name="materialButtonStyle">@style/Widget.App.Button</item>
        <item name="materialCardViewStyle">@style/Widget.App.CardView</item>
    </style>
</resources>