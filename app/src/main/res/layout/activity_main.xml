<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background">

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/headerCard"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        app:cardCornerRadius="0dp"
        app:cardElevation="0dp"
        app:cardBackgroundColor="@android:color/transparent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/main_header_background"
            android:paddingStart="20dp"
            android:paddingTop="26dp"
            android:paddingEnd="20dp"
            android:paddingBottom="26dp">

            <ImageView
                android:id="@+id/ivBrandIcon"
                android:layout_width="130dp"
                android:layout_height="74dp"
                android:adjustViewBounds="true"
                android:contentDescription="@string/app_name"
                android:scaleType="fitCenter"
                android:src="@drawable/foodie_express_logo_transparent"
                app:layout_constraintBottom_toBottomOf="@id/tvTitle"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <TextView
                android:id="@+id/tvDeliveryLabel"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="14dp"
                android:text="@string/home_delivery_label"
                android:textColor="@color/text_on_primary_subtle"
                android:textSize="13sp"
                app:layout_constraintEnd_toStartOf="@id/btnBasket"
                app:layout_constraintStart_toEndOf="@id/ivBrandIcon"
                app:layout_constraintTop_toTopOf="parent" />

            <TextView
                android:id="@+id/tvTitle"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:layout_marginStart="14dp"
                android:fontFamily="sans-serif-medium"
                android:text="@string/home_brand_title"
                android:textSize="26sp"
                android:textColor="@color/white"
                app:layout_constraintStart_toEndOf="@id/ivBrandIcon"
                app:layout_constraintEnd_toStartOf="@id/btnBasket"
                app:layout_constraintTop_toBottomOf="@id/tvDeliveryLabel" />

            <ImageButton
                android:id="@+id/btnBasket"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:scaleType="fitCenter"
                android:src="@drawable/ic_basket"
                android:contentDescription="@string/home_basket_content_description"
                app:tint="@color/food_orange"
                app:layout_constraintBottom_toBottomOf="@id/tvTitle"
                app:layout_constraintEnd_toEndOf="parent" />

            <EditText
                android:id="@+id/etSearch"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_marginTop="16dp"
                android:background="@drawable/search_bar_background"
                android:clickable="true"
                android:cursorVisible="true"
                android:focusable="true"
                android:focusableInTouchMode="true"
                android:hint="@string/home_search_hint"
                android:imeOptions="actionSearch"
                android:importantForAutofill="no"
                android:textColorHint="@color/text_hint"
                android:textColor="@color/text_primary"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:drawableStart="@drawable/ic_search"
                android:drawablePadding="8dp"
                android:inputType="text|textNoSuggestions"
                android:maxLines="1"
                android:singleLine="true"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/tvTitle" />

        </androidx.constraintlayout.widget.ConstraintLayout>
    </com.google.android.material.card.MaterialCardView>

    <LinearLayout
        android:id="@+id/discoverySection"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="16dp"
        android:paddingTop="18dp"
        android:paddingEnd="16dp"
        android:paddingBottom="12dp"
        app:layout_constraintTop_toBottomOf="@id/headerCard"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <HorizontalScrollView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:scrollbars="none">

            <com.google.android.material.chip.ChipGroup
                android:id="@+id/quickFilterGroup"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:singleLine="true"
                app:chipSpacingHorizontal="8dp"
                app:singleSelection="false">

                <com.google.android.material.chip.Chip
                    android:id="@+id/chipTopRated"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:checkable="true"
                    android:text="@string/home_quick_filter_top_rated"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    app:chipBackgroundColor="@color/chip_filter_selector"
                    app:chipStrokeColor="@color/divider"
                    app:chipStrokeWidth="1dp"
                    app:checkedIconVisible="false"
                    app:rippleColor="@color/primary_light"
                    android:textColor="@color/chip_filter_text_selector" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/chipPizza"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:checkable="true"
                    android:text="@string/home_quick_filter_pizza"
                    android:textSize="13sp"
                    app:chipBackgroundColor="@color/chip_filter_selector"
                    app:chipStrokeColor="@color/divider"
                    app:chipStrokeWidth="1dp"
                    app:checkedIconVisible="false"
                    app:rippleColor="@color/primary_light"
                    android:textColor="@color/chip_filter_text_selector" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/chipBurgers"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:checkable="true"
                    android:text="@string/home_quick_filter_burgers"
                    android:textSize="13sp"
                    app:chipBackgroundColor="@color/chip_filter_selector"
                    app:chipStrokeColor="@color/divider"
                    app:chipStrokeWidth="1dp"
                    app:checkedIconVisible="false"
                    app:rippleColor="@color/primary_light"
                    android:textColor="@color/chip_filter_text_selector" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/chipBudget"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:checkable="true"
                    android:text="@string/home_quick_filter_budget"
                    android:textColor="@color/chip_filter_text_selector"
                    android:textSize="13sp"
                    app:checkedIconVisible="false"
                    app:chipBackgroundColor="@color/chip_filter_selector"
                    app:chipStrokeColor="@color/divider"
                    app:chipStrokeWidth="1dp"
                    app:rippleColor="@color/primary_light" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/chipSaved"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:checkable="true"
                    android:text="&#x2764; Saved"
                    android:textColor="@color/chip_filter_text_selector"
                    android:textSize="13sp"
                    app:checkedIconVisible="false"
                    app:chipBackgroundColor="@color/chip_filter_selector"
                    app:chipStrokeColor="@color/divider"
                    app:chipStrokeWidth="1dp"
                    app:rippleColor="@color/primary_light" />

            </com.google.android.material.chip.ChipGroup>
        </HorizontalScrollView>

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardFeaturedNow"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:clickable="true"
            android:focusable="true"
            app:cardBackgroundColor="@color/card_background"
            app:cardCornerRadius="20dp"
            app:cardElevation="0dp"
            app:strokeColor="@color/divider"
            app:strokeWidth="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:padding="16dp">

                <FrameLayout
                    android:layout_width="46dp"
                    android:layout_height="46dp"
                    android:layout_marginEnd="12dp"
                    android:background="@drawable/chip_background_light">

                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:layout_gravity="center"
                        android:contentDescription="@null"
                        android:src="@drawable/ic_restaurant"
                        app:tint="@color/primary" />
                </FrameLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/tvFeaturedLabel"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/home_featured_label"
                        android:textColor="@color/primary"
                        android:textSize="12sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tvFeaturedTitle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="@string/home_featured_title"
                        android:textColor="@color/text_primary"
                        android:textSize="15sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <TextView
                    android:id="@+id/tvFeaturedEta"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/chip_background_light"
                    android:paddingHorizontal="12dp"
                    android:paddingVertical="8dp"
                    android:text="@string/home_featured_eta"
                    android:textColor="@color/primary"
                    android:textSize="12sp"
                    android:textStyle="bold" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:text="@string/home_popular_title"
            android:textColor="@color/text_primary"
            android:textSize="18sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="@string/home_popular_subtitle"
            android:textColor="@color/text_secondary"
            android:textSize="13sp" />
    </LinearLayout>

    <!-- Skeleton loading state (shown while data loads) -->
    <LinearLayout
        android:id="@+id/skeletonContainer"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:orientation="vertical"
        android:visibility="gone"
        app:layout_constraintTop_toBottomOf="@id/discoverySection"
        app:layout_constraintBottom_toTopOf="@id/bottom_nav"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <include layout="@layout/item_skeleton_restaurant" />
        <include layout="@layout/item_skeleton_restaurant" />
        <include layout="@layout/item_skeleton_restaurant" />
    </LinearLayout>

    <ProgressBar
        android:id="@+id/progressRestaurants"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:visibility="gone"
        android:indeterminateTint="@color/primary"
        app:layout_constraintTop_toBottomOf="@id/discoverySection"
        app:layout_constraintBottom_toTopOf="@id/bottom_nav"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <TextView
        android:id="@+id/tvMainStatus"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textColor="@color/text_secondary"
        android:textSize="14sp"
        android:visibility="gone"
        app:layout_constraintTop_toBottomOf="@id/discoverySection"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="20dp" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvRestaurants"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:visibility="gone"
        android:clipToPadding="false"
        android:paddingTop="8dp"
        android:paddingBottom="20dp"
        app:layout_constraintTop_toBottomOf="@id/discoverySection"
        app:layout_constraintBottom_toTopOf="@id/bottom_nav"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Empty state -->
    <LinearLayout
        android:id="@+id/emptyStateContainer"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:visibility="gone"
        app:layout_constraintTop_toBottomOf="@id/discoverySection"
        app:layout_constraintBottom_toTopOf="@id/bottom_nav"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <ImageView
            android:layout_width="80dp"
            android:layout_height="80dp"
            android:src="@drawable/ic_restaurant"
            app:tint="@color/divider"
            android:contentDescription="@string/home_no_restaurants_content_description" />

        <TextView
            android:id="@+id/tvNoFilters"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/home_empty_selected_filters"
            android:textSize="16sp"
            android:textColor="@color/text_secondary"
            android:layout_marginTop="16dp"
            android:gravity="center" />
    </LinearLayout>

    <!-- Bottom Navigation -->
    <include
        android:id="@+id/bottom_nav"
        layout="@layout/bottom_nav"
        android:layout_width="0dp"
        android:layout_height="74dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />
</androidx.constraintlayout.widget.ConstraintLayout>

