<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="8dp"
    app:cardCornerRadius="8dp"
    app:cardElevation="4dp"
    android:background="#FF0000">

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="12dp"
        android:background="#FFF8E1"> <!-- Debug color to test visibility -->

        <!-- Price first (must come before it's referenced) -->
        <TextView
            android:id="@+id/tvPriceCategory"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="$$"
            android:textColor="#5D5FEF"
            android:textSize="16sp"
            android:textStyle="bold"
            android:layout_alignParentEnd="true"
            android:layout_marginStart="8dp"/>

        <!-- Name -->
        <TextView
            android:id="@+id/tvRestaurantName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Restaurant Name"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="#000000"
            android:layout_alignParentStart="true"
            android:layout_toStartOf="@id/tvPriceCategory" />

        <TextView
            android:id="@+id/tvFoodCategory"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Pizzeria"
            android:textColor="#666666"
            android:textSize="14sp"
            android:layout_below="@id/tvRestaurantName"
            android:layout_alignParentStart="true"
            android:layout_marginTop="4dp" />

        <TextView
            android:id="@+id/tvStars"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="★★★"
            android:textColor="#FFD700"
            android:textSize="14sp"
            android:layout_below="@id/tvFoodCategory"
            android:layout_alignParentStart="true"
            android:layout_marginTop="4dp" />

        <Button
            android:id="@+id/btnView"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="View"
            android:textSize="14sp"
            android:backgroundTint="#EEEEEE"
            android:textColor="#000000"
            android:layout_alignParentEnd="true"
            android:layout_below="@id/tvStars"
            android:layout_marginTop="8dp" />
    </RelativeLayout>
</androidx.cardview.widget.CardView>
