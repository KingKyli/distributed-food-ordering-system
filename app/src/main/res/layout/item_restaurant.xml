<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="16dp"
    android:layout_marginBottom="16dp"
    app:cardCornerRadius="16dp"
    app:cardElevation="2dp"
    app:cardBackgroundColor="@color/card_background">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Badge -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="10dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/chip_background_neutral"
                android:paddingHorizontal="10dp"
                android:paddingVertical="4dp"
                android:text="Fast delivery"
                android:textColor="#475569"
                android:textSize="12sp"
                android:textStyle="normal" />

            <Space
                android:layout_width="0dp"
                android:layout_height="1dp"
                android:layout_weight="1" />

            <!-- Favorite Icon -->
            <ImageView
                android:id="@+id/ivHeart"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:padding="6dp"
                android:src="@drawable/ic_heart_outline"
                android:contentDescription="Add to favourites"
                app:tint="#64748B" />
        </LinearLayout>

        <!-- Content: Image + Info -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="14dp">

            <!-- Restaurant Image (food photo from spritesheet) -->
            <ImageView
                android:id="@+id/ivRestaurantIcon"
                android:layout_width="80dp"
                android:layout_height="80dp"
                android:src="@drawable/ic_restaurant"
                android:background="@drawable/restaurant_card_header_background"
                android:scaleType="centerCrop"
                android:clipToOutline="true"
                android:contentDescription="Restaurant photo" />

            <!-- Info: Name, Category, Meta -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:layout_marginStart="12dp"
                android:layout_gravity="center_vertical">

                <!-- Restaurant Name -->
                <TextView
                    android:id="@+id/tvRestaurantName"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="BBQ Nation"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="#0F172A"
                    android:maxLines="1"
                    android:ellipsize="end" />

                <!-- Category -->
                <TextView
                    android:id="@+id/tvFoodCategory"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="BBQ"
                    android:textColor="#64748B"
                    android:textSize="13sp"
                    android:layout_marginTop="2dp" />

                <!-- Meta: Rating + Time -->
                <TextView
                    android:id="@+id/tvRating"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="⭐ 4.0 • 20-30 min"
                    android:textColor="#64748B"
                    android:textSize="13sp"
                    android:layout_marginTop="4dp" />
            </LinearLayout>
        </LinearLayout>

        <!-- Actions Row: Secondary + Primary Buttons -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <!-- View Menu Button (Secondary) -->
            <com.example.restaurantapp.ui.components.SecondaryButton
                android:id="@+id/btnOpen"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginEnd="5dp" />

            <!-- Order Now Button (Primary) -->
            <com.example.restaurantapp.ui.components.PrimaryButton
                android:id="@+id/btnOrder"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="5dp" />
        </LinearLayout>

        <!-- Hidden elements for backward compatibility -->
        <TextView
            android:id="@+id/tvPriceCategory"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:visibility="gone" />

        <TextView
            android:id="@+id/tvStars"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:visibility="gone" />
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
